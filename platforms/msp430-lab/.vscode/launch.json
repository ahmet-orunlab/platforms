{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MSP430 Görsel Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceRoot}/build/main.elf",
            "stopAtEntry": true,
            "cwd": "${workspaceRoot}",
            "MIMode": "gdb",
            
            // Doğrudan bizim hazırladığımız aracı betiği çağırıyoruz
            "miDebuggerPath": "${workspaceRoot}/gdb_wrapper.sh",
            
            "setupCommands": [
                {
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "text": "target remote localhost:2000",
                    "ignoreFailures": false
                }
            ],
            "logging": { "engineLogging": true }
        }
    ]
}
