{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "MSP430: 1. Projeyi Derle (Make)",
            "type": "shell",
            // docker exec yerine doğrudan konteyner içindeki make'i çağırıyoruz
            "command": "make -C /workspace",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "MSP430: 2. Direkt Flash Belleğe Yaz (Flash)",
            "type": "shell",
            // docker exec kısımları temizlendi, doğrudan mspdebug komutları çalışıyor
            "command": "sudo pkill mspdebug || true; sudo mspdebug rf2500 'prog /workspace/build/main.elf'",
            "dependsOn": [
                "MSP430: 1. Projeyi Derle (Make)"
            ],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "MSP430: GDB Sunucusunu Baslat",
            "type": "shell",
            // docker exec kısımları temizlendi.
            "command": "sudo pkill mspdebug || true; sleep 1; sudo mspdebug rf2500 'gdb 3333'",
            "isBackground": true,
            "dependsOn": [
                "MSP430: 2. Direkt Flash Belleğe Yaz (Flash)"
            ],
            "problemMatcher": {
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Initializing FET...",
                    "endsPattern": "Bound to port 3333. Now waiting for connection..."
                }
            },
            "presentation": { "reveal": "silent", "panel": "shared" }
        }
    ]
}
