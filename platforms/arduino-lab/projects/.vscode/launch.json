{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Arduino Uno Simulasyon Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/firmware.elf",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/avr-gdb",
            "miDebuggerServerAddress": "localhost:1234",
            "preLaunchTask": "3 - Arduino Uno: Simulasyon GDB Sunucusunu Baslat",
            "stopAtEntry": true,
            "stopAtConnect": true,
            "launchCompleteCommand": "None",
            "setupCommands": [
                {
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "logging": {
                "engineLogging": true,
                "trace": true,
                "traceResponse": true
            }
        }
    ]
}
