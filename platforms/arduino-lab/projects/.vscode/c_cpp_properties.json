{
    "version": 4,
    "configurations": [
        {
            "name": "Arduino Uno AVR",
            "compilerPath": "/usr/bin/avr-gcc",
            "compilerArgs": [
                "-mmcu=atmega328p"
            ],
            "includePath": [
                "${workspaceFolder}/src",
                "/usr/lib/avr/include",
                "/usr/lib/gcc/avr/**/include"
            ],
            "defines": [
                "F_CPU=16000000UL",
                "__AVR_ATmega328P__"
            ],
            "cStandard": "gnu11",
            "intelliSenseMode": "gcc-x64",
            "browse": {
                "path": [
                    "${workspaceFolder}/src",
                    "/usr/lib/avr/include",
                    "/usr/lib/gcc/avr/**/include"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ]
}
